# LogRocket MCP (project-scoped API key from Settings > API Keys)
LOGROCKET_API_KEY=lr_...
LOGROCKET_ORG_ID=your_org_id
LOGROCKET_PROJECT_ID=your_project_id

# Local LLM (Ollama OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3-coder:30b

# Optional: where generated tests are written
E2E_OUTPUT_DIR=./generated-tests

# PII safety for production LogRocket sessions
PII_SANITIZE=true
FAKER_SEED=42
SOURCE_ENV=production

# Staging target for fixture recording (record-fixtures command)
STAGING_BASE_URL=https://staging.example.com
PLAYWRIGHT_BROWSER=chromium
